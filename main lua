local ctx = service or activity
local dataDir = "/sdcard/Documents"
local pluginPath = "/sdcard/解说/Plugins/Squad Master/main.lua"
local updateUrl = "https://raw.githubusercontent.com/rizwanhafiz962-gif/Rizwan123123/main/main.lua"
local versionUrl = "https://raw.githubusercontent.com/rizwanhafiz962-gif/Rizwan123123/main/version.txt"
local CURRENT_VERSION = "2.5"

require "import"
import "android.widget.*"
import "android.net.Uri"
import "android.content.Intent"
import "android.view.*"
import "java.io.File"
import "android.content.Context"
import "android.os.Handler"
import "android.os.Looper"
import "android.content.ClipboardManager"
import "android.content.ClipData"
import "android.text.InputType"
import "android.view.accessibility.AccessibilityEvent"
import "com.androlua.Http"
import "cjson"

local mainHandler = Handler(Looper.getMainLooper())

function checkUpdate()
    Http.get(versionUrl, function(code, response)
        if code == 200 and response then
            if trim(response) ~= CURRENT_VERSION then
                mainHandler.post(Runnable({run = function()
                    local updateDlg = LuaDialog(ctx)
                    updateDlg.setTitle("Update Available")
                    updateDlg.setMessage("A new version is available. Update now?")
                    updateDlg.setButton("Update", function() performUpdate() end)
                    updateDlg.setButton2("Cancel", function() end)
                    updateDlg.show()
                end}))
            end
        end
    end)
end

function performUpdate()
    Http.get(updateUrl, function(code, body)
        if code == 200 then
            local f = io.open(pluginPath, "w")
            if f then
                f:write(body)
                f:close()
                showToast("Update successful! Please restart.")
            end
        end
    end)
end

function trim(s) return s:gsub("^%s*(.-)%s*$", "%1") end

local dataFile = dataDir .. "/squad_data.txt"
local feedbackFile = dataDir .. "/feedback_data.txt"

local APP_PREFS = "SquadMaster_Prefs"
local prefs = ctx.getSharedPreferences(APP_PREFS, Context.MODE_PRIVATE)

function isVibrationEnabled() return prefs.getBoolean("vibration", true) end
function isSoundEnabled() return prefs.getBoolean("sound", true) end

function triggerFeedback()
    if isVibrationEnabled() then
        pcall(function() ctx.getSystemService(Context.VIBRATOR_SERVICE).vibrate(50) end)
    end
end

checkUpdate()
