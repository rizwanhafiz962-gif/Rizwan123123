end

function copyToClipboard(text, squadDlg)
  pcall(function()
    triggerFeedback()
    local clipboard = ctx.getSystemService(Context.CLIPBOARD_SERVICE)
    local clip = ClipData.newPlainText("label", text)
    clipboard.setPrimaryClip(clip)
    
    if service then
      pcall(function() if service.asyncSpeak then service.asyncSpeak("Copied to clipboard", 0) end end)
      pcall(function() if service.appendSpeak then service.appendSpeak("Copied to clipboard") end end)
    end
    
    showToast("Copied to clipboard")
    
    if squadDlg then 
      local view = squadDlg.getContext()
      if view then
        view.getSystemService(Context.ACCESSIBILITY_SERVICE).sendAccessibilityEvent(
          AccessibilityEvent.obtain().setEventType(AccessibilityEvent.TYPE_ACCESSIBILITY_FOCUS).setClassName(view.getClass().getName()).setPackageName(ctx.getPackageName()).getText().add("Copied to clipboard")
        )
      end
      squadDlg.dismiss() 
    end
  end)
end

pcall(function()
  local dirFile = File(dataDir)
  if not dirFile.exists() then 
    dirFile.mkdirs() 
  end
end)

function loadData()
  squadNames = {}
  pcall(function()
    local f = io.open(dataFile, "r")
    if f then
      local content = f:read("*all")
      f:close()
      if content and content ~= "" then
        for block in content:gmatch("(.-)%[---END---%]\n*") do
          if block ~= "" then
            table.insert(squadNames, block)
          end
        end
      end
    end
  end)
end

function saveData()
  pcall(function()
    local f = io.open(dataFile, "w")
    if f then
      for _, name in ipairs(squadNames) do 
        f:write(name .. "[---END---]\n") 
      end
      f:close()
    end
  end)
end

function clearAllData()
  squadNames = {}
  saveData()
end

